# @@PKG_NAME@@ Debian control — generated by pkg_gen.sh from pkg_lib templates
#
# Placeholders:
#   @@PKG_NAME@@           — package name
#   @@PKG_SUMMARY@@        — one-line description
#   @@PKG_DESCRIPTION@@    — multi-line description (leading space, . for blank lines)
#   @@PKG_URL@@            — upstream homepage URL
#   @@PKG_MAINTAINER@@     — maintainer in "Name <email>" format
#   @@PKG_DEB_DEPENDS@@    — comma-separated dependency list
#   @@PKG_DEB_RECOMMENDS@@ — comma-separated recommends list
#   @@PKG_DEB_SUGGESTS@@   — comma-separated suggests list
#
Source: @@PKG_NAME@@
Section: admin
Priority: optional
Maintainer: @@PKG_MAINTAINER@@
Build-Depends: debhelper-compat (= 13)
Standards-Version: 4.6.2
Homepage: @@PKG_URL@@

Package: @@PKG_NAME@@
Architecture: all
Depends: @@PKG_DEB_DEPENDS@@, ${misc:Depends}
Recommends: @@PKG_DEB_RECOMMENDS@@
Suggests: @@PKG_DEB_SUGGESTS@@
Description: @@PKG_SUMMARY@@
@@PKG_DESCRIPTION@@
