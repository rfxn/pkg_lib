#!/bin/bash
# @@PKG_NAME@@ postinst — generated by pkg_gen.sh from pkg_lib templates
#
# Post-install scriptlet: sets permissions, runs config migration if
# upgrading from install.sh-based installation.
#
# Placeholders:
#   @@PKG_NAME@@            — package name
#   @@PKG_INSTALL_PATH@@    — legacy install path
#   @@PKG_POSTINST_PERMS@@  — chmod commands for config/state files
#   @@PKG_POSTINST_EXTRA@@  — project-specific post-install commands (optional)
#
set -e

LEGACY_PATH="@@PKG_INSTALL_PATH@@"

case "$1" in
    configure)
@@PKG_POSTINST_PERMS@@
        # Run importconf if migrating from install.sh backup
        if [ -d "${LEGACY_PATH}.bk.last" ]; then
            if [ -x /usr/lib/@@PKG_NAME@@/importconf ]; then
                INSTALL_PATH="$LEGACY_PATH" /usr/lib/@@PKG_NAME@@/importconf || true
            fi
        fi
@@PKG_POSTINST_EXTRA@@
        ;;
esac

#DEBHELPER#

exit 0
