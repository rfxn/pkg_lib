#!/bin/bash
# @@PKG_NAME@@ postrm — generated by pkg_gen.sh from pkg_lib templates
#
# Post-remove scriptlet: cleans up symlink farm directory, state, and
# config on purge.
#
# Placeholders:
#   @@PKG_NAME@@          — package name
#   @@PKG_INSTALL_PATH@@  — legacy install path
#   @@PKG_BIN_LEGACY@@    — legacy binary path (e.g., /usr/local/sbin/bfd)
#   @@PKG_POSTRM_EXTRA@@  — project-specific post-remove commands (optional)
#
set -e

case "$1" in
    remove)
        # Clean up the symlink farm directory (links are removed by dpkg,
        # but the directory itself and any runtime-created files remain)
        rm -rf @@PKG_INSTALL_PATH@@ 2>/dev/null || true
        rm -f @@PKG_BIN_LEGACY@@ 2>/dev/null || true
        if command -v systemctl >/dev/null 2>&1; then
            systemctl daemon-reload 2>/dev/null || true
        fi
        ;;
    purge)
        # Clean up symlink farm
        rm -rf @@PKG_INSTALL_PATH@@ 2>/dev/null || true
        rm -f @@PKG_BIN_LEGACY@@ 2>/dev/null || true
        # Remove config directory on purge
        rm -rf /etc/@@PKG_NAME@@ 2>/dev/null || true
        # Remove state
        rm -rf /var/lib/@@PKG_NAME@@ 2>/dev/null || true
@@PKG_POSTRM_EXTRA@@
        if command -v systemctl >/dev/null 2>&1; then
            systemctl daemon-reload 2>/dev/null || true
        fi
        ;;
esac

#DEBHELPER#

exit 0
