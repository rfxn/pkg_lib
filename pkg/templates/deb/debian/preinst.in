#!/bin/bash
# @@PKG_NAME@@ preinst — generated by pkg_gen.sh from pkg_lib templates
#
# Pre-install scriptlet: detects and backs up existing install.sh-based
# installations before package lays down FHS files.
#
# Placeholders:
#   @@PKG_NAME@@           — package name
#   @@PKG_INSTALL_PATH@@   — legacy install path (e.g., /usr/local/bfd)
#   @@PKG_BIN_NAME@@       — binary name (e.g., bfd)
#   @@PKG_PREINST_EXTRA@@  — project-specific pre-install commands (optional)
#
set -e

LEGACY_PATH="@@PKG_INSTALL_PATH@@"

case "$1" in
    install|upgrade)
        # Detect and back up existing install.sh-based installation
        # A real (non-package) install has the binary as a regular file,
        # not a symlink (which package installs create via symlink farm)
        if [ -f "$LEGACY_PATH/@@PKG_BIN_NAME@@" ] && [ ! -L "$LEGACY_PATH/internals" ] && [ ! -L "$LEGACY_PATH/@@PKG_BIN_NAME@@" ]; then
            # This is a real (non-package) install — back up
            _bkdir="${LEGACY_PATH}.bk.$(date +%Y%m%d-%s)"
            echo "Backing up existing install.sh installation to $_bkdir"
            cp -a "$LEGACY_PATH" "$_bkdir"
            rm -f "${LEGACY_PATH}.bk.last"
            ln -s "$_bkdir" "${LEGACY_PATH}.bk.last"
            # Preserve state files
            if [ -d "$LEGACY_PATH/tmp" ]; then
                mkdir -p /var/lib/@@PKG_NAME@@/tmp
                # cp may fail if tmp/ is empty — safe to ignore
                cp -a "$LEGACY_PATH"/tmp/* /var/lib/@@PKG_NAME@@/tmp/ 2>/dev/null || true
            fi
            # Stop SysVinit services if present
            for _initdir in /etc/rc.d/init.d /etc/init.d; do
                if [ -f "$_initdir/@@PKG_BIN_NAME@@" ]; then
                    "$_initdir/@@PKG_BIN_NAME@@" stop 2>/dev/null || true
                    if command -v chkconfig >/dev/null 2>&1; then
                        chkconfig --del @@PKG_BIN_NAME@@ 2>/dev/null || true
                    elif command -v update-rc.d >/dev/null 2>&1; then
                        update-rc.d -f @@PKG_BIN_NAME@@ remove 2>/dev/null || true
                    fi
                fi
            done
            # Stop systemd services before removing old install
            if command -v systemctl >/dev/null 2>&1; then
                systemctl stop @@PKG_BIN_NAME@@.service 2>/dev/null || true
            fi
            # Remove old install — package will lay down new files
            rm -rf "$LEGACY_PATH"
        fi
@@PKG_PREINST_EXTRA@@
        ;;
esac

#DEBHELPER#

exit 0
