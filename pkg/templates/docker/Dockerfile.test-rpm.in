# @@PKG_NAME@@ RPM install verification — Rocky 9
# Generated by pkg_gen.sh from pkg_lib templates
#
# Placeholders:
#   @@PKG_NAME@@             — package name
#   @@PKG_RPM_TEST_DEPS@@    — runtime dependencies to install before testing
#
FROM rockylinux:9

# Install dependencies that @@PKG_NAME@@ requires at runtime
RUN dnf install -y --allowerasing @@PKG_RPM_TEST_DEPS@@ && \
    dnf clean all

# Copy RPM and test script from build context
COPY @@PKG_NAME@@-*el9*.rpm /tmp/
COPY test-pkg-install.sh /test/test-pkg-install.sh

# Install the package
RUN rpm -ivh /tmp/@@PKG_NAME@@-*el9*.rpm

CMD ["/test/test-pkg-install.sh", "rpm"]
