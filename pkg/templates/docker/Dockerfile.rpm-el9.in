# @@PKG_NAME@@ RPM build environment — Rocky 9 (el8/el9/el10)
# Generated by pkg_gen.sh from pkg_lib templates
#
# Placeholders:
#   @@PKG_NAME@@ — package name
#
FROM rockylinux:9

RUN dnf install -y rpm-build tar gzip make && \
    dnf clean all

# Copy project source
COPY . /src/@@PKG_NAME@@

WORKDIR /src/@@PKG_NAME@@/pkg

# Build tarball and RPMs for el8, el9, el10
RUN make source && \
    mkdir -p /root/rpmbuild/{SOURCES,SPECS,BUILD,RPMS,SRPMS} && \
    cp build/@@PKG_NAME@@-*.tar.gz /root/rpmbuild/SOURCES/ && \
    cp rpm/@@PKG_NAME@@.spec /root/rpmbuild/SPECS/ && \
    rpmbuild -bb --define "dist .el8" /root/rpmbuild/SPECS/@@PKG_NAME@@.spec && \
    rpmbuild -bb --define "dist .el9" /root/rpmbuild/SPECS/@@PKG_NAME@@.spec && \
    rpmbuild -bb --define "dist .el10" /root/rpmbuild/SPECS/@@PKG_NAME@@.spec

CMD cp /root/rpmbuild/RPMS/noarch/*.rpm /output/
