# @@PKG_NAME@@ DEB install verification — Debian 12
# Generated by pkg_gen.sh from pkg_lib templates
#
# Placeholders:
#   @@PKG_NAME@@             — package name
#   @@PKG_DEB_TEST_DEPS@@    — runtime dependencies to install before testing
#
FROM debian:12

# Install dependencies that @@PKG_NAME@@ requires at runtime
RUN apt-get update && \
    apt-get install -y --no-install-recommends @@PKG_DEB_TEST_DEPS@@ && \
    rm -rf /var/lib/apt/lists/*

# Copy DEB and test script from build context
COPY @@PKG_NAME@@_*.deb /tmp/
COPY test-pkg-install.sh /test/test-pkg-install.sh

# Install the package (use dpkg + apt fix-broken for dependency resolution)
RUN dpkg -i /tmp/@@PKG_NAME@@_*.deb || apt-get install -f -y

CMD ["/test/test-pkg-install.sh", "deb"]
