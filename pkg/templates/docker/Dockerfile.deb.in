# @@PKG_NAME@@ DEB build environment — Debian 12
# Generated by pkg_gen.sh from pkg_lib templates
#
# Placeholders:
#   @@PKG_NAME@@        — package name
#   @@PKG_VERSION_CMD@@ — shell command to extract version from source tree
#
FROM debian:12

RUN apt-get update && \
    apt-get install -y --no-install-recommends \
        build-essential debhelper devscripts tar gzip make && \
    rm -rf /var/lib/apt/lists/*

# Copy project source
COPY . /src/@@PKG_NAME@@

WORKDIR /src/@@PKG_NAME@@/pkg

# Build tarball, then DEB — use explicit version to avoid glob issues
RUN set -e && \
    VERSION=$(@@PKG_VERSION_CMD@@) && \
    make source && \
    mkdir -p build/deb-build && \
    cd build/deb-build && \
    tar xzf "../@@PKG_NAME@@-${VERSION}.tar.gz" && \
    cp -a /src/@@PKG_NAME@@/pkg/deb/debian "@@PKG_NAME@@-${VERSION}/debian" && \
    cd "@@PKG_NAME@@-${VERSION}" && \
    dpkg-buildpackage -us -uc -b

CMD cp /src/@@PKG_NAME@@/pkg/build/deb-build/*.deb /output/
