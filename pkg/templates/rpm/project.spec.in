# @@PKG_NAME@@ RPM spec — generated by pkg_gen.sh from pkg_lib templates
#
# Placeholders (substituted by pkg_gen.sh from project manifest):
#   @@PKG_NAME@@             — package name (e.g., bfd, apf, maldet)
#   @@PKG_VERSION@@          — version string (e.g., 2.0.1)
#   @@PKG_SUMMARY@@          — one-line package summary
#   @@PKG_DESCRIPTION@@      — multi-line package description
#   @@PKG_LICENSE@@           — license identifier (e.g., GPLv2+)
#   @@PKG_URL@@              — upstream URL
#   @@PKG_MAINTAINER@@       — maintainer name + email
#   @@PKG_INSTALL_PATH@@     — legacy install path (e.g., /usr/local/bfd)
#   @@PKG_BIN_NAME@@         — binary name in /usr/sbin
#   @@PKG_BIN_LEGACY@@       — legacy binary path (e.g., /usr/local/sbin/bfd)
#   @@PKG_SECTION@@          — man page section (e.g., 1, 8)
#   @@PKG_COPYRIGHT_START@@  — copyright start year (e.g., 1999, 2002)
#   @@PKG_RPM_REQUIRES@@     — Requires: lines (one per line)
#   @@PKG_RPM_WEAK_DEPS@@    — Recommends/Suggests lines (conditional on el8+)
#   @@PKG_RPM_BUILD_SECTION@@     — %build section commands
#   @@PKG_RPM_INSTALL_SECTION@@   — %install section commands
#   @@PKG_RPM_PRE_SECTION@@       — %pre scriptlet body
#   @@PKG_RPM_POST_SECTION@@      — %post scriptlet body
#   @@PKG_RPM_PREUN_SECTION@@     — %preun scriptlet body
#   @@PKG_RPM_POSTUN_SECTION@@    — %postun scriptlet body
#   @@PKG_RPM_FILES_SECTION@@     — %files listing
#   @@PKG_RPM_CHANGELOG@@         — %changelog entries
#
%define name    @@PKG_NAME@@
%define version @@PKG_VERSION@@
%define release 1%{?dist}

# Legacy install path used by install.sh — symlink farm target
%define legacy_path @@PKG_INSTALL_PATH@@

Name:           %{name}
Version:        %{version}
Release:        %{release}
Summary:        @@PKG_SUMMARY@@
License:        @@PKG_LICENSE@@
URL:            @@PKG_URL@@
Source0:        %{name}-%{version}.tar.gz
BuildArch:      noarch

@@PKG_RPM_REQUIRES@@
@@PKG_RPM_WEAK_DEPS@@

%description
@@PKG_DESCRIPTION@@

%prep
%setup -q -n %{name}-%{version}

%build
@@PKG_RPM_BUILD_SECTION@@

%install
rm -rf %{buildroot}
@@PKG_RPM_INSTALL_SECTION@@

%pre
@@PKG_RPM_PRE_SECTION@@

%post
@@PKG_RPM_POST_SECTION@@

%preun
@@PKG_RPM_PREUN_SECTION@@

%postun
@@PKG_RPM_POSTUN_SECTION@@

%files
%license COPYING.GPL
@@PKG_RPM_FILES_SECTION@@

%changelog
@@PKG_RPM_CHANGELOG@@
